<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-apple-disable-message-reformatting" />
    <title>Application Status Update</title>
    <style>
      body, table, td, a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
        text-size-adjust: 100%;
        margin: 0;
        padding: 0;
      }
      body {
        width: 100%;
        height: 100%;
        font-family: "Arial", sans-serif;
        color: rgba(255, 255, 255, 1);
        line-height: 1.6;
      }
      table {
        border-collapse: collapse !important;
        width: 100%;
      }
      .email-container {
        max-width: 600px;
        margin: 40px auto;
        background-color: rgba(24, 24, 27, 1);
        border-radius: 10px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
        overflow: hidden;
      }
      .email-header {
        background-color: rgba(244, 198, 51, 1);
        padding: 24px;
        text-align: center;
      }
      .email-header img {
        width: 180px;
        height: auto;
        margin-bottom: 14px;
      }
      .email-header h1 {
        font-size: 20px;
        margin: 0;
        font-weight: 600;
        color: rgba(24, 24, 27, 1);
      }
      .notification-banner {
        background-color: rgba(255, 255, 255, 0.05);
        padding: 16px 24px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }
      .notification-title {
        font-size: 20px;
        color: rgba(244, 198, 51, 1);
        margin: 0;
        font-weight: 600;
      }
      .notification-meta {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
        margin-top: 4px;
      }
      .email-body {
        padding: 24px;
        color: rgba(255, 255, 255, 0.9);
      }
      .status-card {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 20px;
        margin: 16px 0;
      }
      .company-info {
        display: flex;
        align-items: center;
        margin-bottom: 16px;
      }
      .company-logo {
        width: 48px;
        height: 48px;
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        margin-right: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .company-logo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .company-name {
        font-size: 16px;
        font-weight: 600;
        color: rgba(244, 198, 51, 1);
      }
      .job-title {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
      }
      .status-info {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
      }
      .status-label {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 8px;
      }
      .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 16px;
        font-size: 13px;
        font-weight: 500;
        text-transform: capitalize;
      }
      .status-viewed {
        background-color: #1976d2;
        color: white;
      }
      .status-shortlisted {
        background-color: #2e7d32;
        color: white;
      }
      .status-interviewing {
        background-color: #f57c00;
        color: white;
      }
      .status-accepted {
        background-color: #2e7d32;
        color: white;
      }
      .status-rejected {
        background-color: #c62828;
        color: white;
      }
      .feedback-box {
        margin-top: 16px;
        padding: 16px;
        background-color: rgba(255, 255, 255, 0.05);
        border-radius: 6px;
        color: rgba(255, 255, 255, 0.9);
      }
      .action-button {
        display: inline-block;
        text-decoration: none;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 600;
        border-radius: 6px;
        margin-top: 24px;
        background-color: rgba(244, 198, 51, 1);
        color: rgba(24, 24, 27, 1);
        transition: 0.3s;
      }
      .action-button:hover {
        background-color: rgba(255, 204, 51, 1);
      }
      .timeline {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
      }
      .timeline-item {
        display: flex;
        align-items: flex-start;
        margin-bottom: 16px;
      }
      .timeline-dot {
        width: 10px;
        height: 10px;
        background-color: rgba(244, 198, 51, 1);
        border-radius: 50%;
        margin-right: 12px;
        margin-top: 6px;
      }
      .timeline-content {
        flex: 1;
        color: rgba(255, 255, 255, 0.9);
      }
      .timeline-date {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.5);
      }
      .email-footer {
        background-color: rgba(0, 0, 0, 1);
        text-align: center;
        padding: 24px;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.55);
        border-top: 1px solid rgba(174, 174, 174, 1);
      }
      @media screen and (max-width: 600px) {
        .email-container {
          width: 100% !important;
          margin: 0 !important;
        }
        .email-body, .email-header, .email-footer {
          padding: 16px;
        }
      }
    </style>
  </head>
  <body>
    <center>
      <table role="presentation" class="email-container">
        <tr>
          <td class="email-header">
            <img src="{{backend_url}}/images/defaults/app-logo.png" alt="{{company_name}} Logo" />
            <h1>{{notification_title}}</h1>
          </td>
        </tr>
        <tr>
          <td class="notification-banner">
            <p class="notification-meta">Date: {{update_date}}</p>
          </td>
        </tr>
        <tr>
          <td class="email-body">
            <div class="status-card">
              <div class="company-info">
                <div class="company-logo">
                  {{#if organization_logo}}
                    <img src="{{organization_logo}}" alt="{{organization_name}}" onerror="this.style.display='none'" />
                  {{/if}}
                </div>
                <div>
                  <div class="company-name">{{organization_name}}</div>
                  <div class="job-title">{{job_title}}</div>
                </div>
              </div>
              
              <div class="status-info">
                <div class="status-label">Application Status</div>
                <div class="status-badge status-{{status_class}}">
                  {{status}}
                </div>
                {{#if feedback}}
                <div class="feedback-box">
                  <strong>Feedback from employer:</strong><br>
                  {{feedback}}
                </div>
                {{/if}}
              </div>

              <div class="timeline">
                <div class="timeline-item">
                  <div class="timeline-dot"></div>
                  <div class="timeline-content">
                    <div>Application {{status}}</div>
                    <div class="timeline-date">{{update_date}}</div>
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="timeline-dot"></div>
                  <div class="timeline-content">
                    <div>Application submitted</div>
                    <div class="timeline-date">{{application_date}}</div>
                  </div>
                </div>
              </div>

              <center>
                <a href="{{dashboard_link}}" class="action-button">View Application Details</a>
              </center>
            </div>

            <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); margin-top: 24px; text-align: center;">
              You can track all your job applications and their status in your dashboard. Good luck with your job search!
            </p>
          </td>
        </tr>
        <tr>
          <td class="email-footer">
            &copy; {{year}} {{company_name}}. All rights reserved.
          </td>
        </tr>
      </table>
    </center>
  </body>
</html> 