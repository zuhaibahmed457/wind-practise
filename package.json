{
  "name": "wind-tech-pro-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:prod": "cross-env NODE_ENV=production nest start",
    "seed:dev": "cross-var cross-env NODE_ENV=development ts-node -r tsconfig-paths/register ./seeds/$npm_config_filename",
    "seed:prod": "cross-var cross-env NODE_ENV=production ts-node -r tsconfig-paths/register ./seeds/$npm_config_filename",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm:generate-migration": "cross-var cross-env NODE_ENV=$npm_config_environment npx typeorm-ts-node-commonjs migration:generate ./migrations/$npm_config_filename -d ./typeorm.config.ts",
    "typeorm:run-migrations": "cross-var cross-env NODE_ENV=$npm_config_environment npx typeorm-ts-node-commonjs migration:run -d ./typeorm.config.ts",
    "typeorm:create-migration": "cross-var cross-env NODE_ENV=$npm_config_environment typeorm-ts-node-commonjs migration:create ./migrations/$npm_config_filename",
    "typeorm:revert-migrations": "cross-var cross-env NODE_ENV=$npm_config_environment npx typeorm-ts-node-commonjs migration:revert -d ./typeorm.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.749.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bull": "^11.0.2",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.0.10",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^11.0.10",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.20.3",
    "bull": "^4.16.5",
    "bullmq": "^5.41.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cross-env": "^7.0.3",
    "cross-var": "^1.1.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "handlebars": "^4.7.8",
    "install": "^0.13.0",
    "nestjs-form-data": "^1.9.92",
    "nestjs-typeorm-paginate": "^4.0.4",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.0",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "stripe": "^17.6.0",
    "typeorm": "^0.3.20",
    "ua-parser-js": "^2.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
